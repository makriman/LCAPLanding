---
import en from "../data/en.json";
import fil from "../data/fil.json";
import "../styles/global.css";

const translations = { en, fil };
const defaultCopy = en;

const sendCurrencies = ["USD", "GBP", "EUR", "CAD", "SGD", "AED"];
const sendCurrencyFlags = {
  USD: "/flags/us.svg",
  GBP: "/flags/gb.svg",
  EUR: "/flags/eu.svg",
  CAD: "/flags/ca.svg",
  SGD: "/flags/sg.svg",
  AED: "/flags/ae.svg",
};

const referenceAmount = 1000;
const fallbackMidRate = 56.2;
const tableProviders = [
  { id: "aspora", name: "Aspora", marginPct: 0.15, fee: 3 },
  { id: "remitly", name: "Remitly", marginPct: 1.1, fee: 1.99 },
  { id: "skrill", name: "Skrill", marginPct: 1.3, fee: 0 },
  { id: "wise", name: "Wise", marginPct: 0.2, fee: 5.68 },
  { id: "western-union", name: "Western Union", marginPct: 1.8, fee: 2.5 },
];

const initialRows = tableProviders.map((provider) => {
  const effectiveRate = fallbackMidRate * (1 - provider.marginPct / 100);
  const recipientGets = Math.max((referenceAmount - provider.fee) * effectiveRate, 0);

  return {
    ...provider,
    effectiveRate,
    recipientGets,
  };
});

const asporaBase = initialRows.find((row) => row.id === "aspora")?.recipientGets ?? 0;
const bestCompetitorBase = Math.max(...initialRows.filter((row) => row.id !== "aspora").map((row) => row.recipientGets));
const initialSaveValue = Math.max(asporaBase - bestCompetitorBase, 0);

const testimonialFlags = [
  { fromFlag: "/flags/us.svg", toFlag: "/flags/ph.svg" },
  { fromFlag: "/flags/ca.svg", toFlag: "/flags/ph.svg" },
  { fromFlag: "/flags/ae.svg", toFlag: "/flags/ph.svg" },
];

const trustItems = [
  { key: "hero.ticker.item3", text: defaultCopy.hero.ticker.item3 },
  { key: "hero.ticker.item2", text: defaultCopy.hero.ticker.item2 },
  { key: "hero.ticker.item1", text: defaultCopy.hero.ticker.item1 },
];

const featuredOutlets = ["CNBC", "YourStory", "Entrepreneur", "Economic Times", "Gulf News"];
const liveCountries = ["US", "UK", "UAE", "EU", "SG", "PH"];
const arrivingSoonCountries = ["SA", "FR", "ES", "NL", "CA"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{defaultCopy.meta.title}</title>
    <meta name="description" content={defaultCopy.meta.description} />
    <meta property="og:title" content={defaultCopy.meta.title} />
    <meta property="og:description" content={defaultCopy.meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Aspora" />
    <meta property="og:url" content="https://www.aspora.com" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header id="siteHeader" class="site-header">
      <div class="site-shell site-header-inner">
        <a
          href="#hero"
          class="brand"
          aria-label={defaultCopy.header.brandAria}
          data-i18n-aria-label="header.brandAria"
        >
          <span class="brand-wordmark">Aspora</span>
        </a>

        <nav class="desktop-nav" aria-label="Primary">
          <a href="#hero" data-i18n="header.nav.sendMoney">
            {defaultCopy.header.nav.sendMoney}
            <span class="new-pill" data-i18n="header.nav.newTag">{defaultCopy.header.nav.newTag}</span>
          </a>
          <a href="#gateway" data-i18n="header.nav.payBills">{defaultCopy.header.nav.payBills}</a>
          <a href="#security" data-i18n="header.nav.aboutUs">{defaultCopy.header.nav.aboutUs}</a>
          <a href="#footer" data-i18n="header.nav.careers">{defaultCopy.header.nav.careers}</a>
          <a href="#featured" data-i18n="header.nav.blog">{defaultCopy.header.nav.blog}</a>
        </nav>

        <div class="desktop-actions">
          <div
            class="language-switch"
            aria-label={defaultCopy.header.language.label}
            data-i18n-aria-label="header.language.label"
          >
            <button type="button" data-lang="en" data-i18n="header.language.english">{defaultCopy.header.language.english}</button>
            <button type="button" data-lang="fil" data-i18n="header.language.filipino">{defaultCopy.header.language.filipino}</button>
          </div>
          <a href="#download" class="btn-primary btn-nav" data-i18n="finalCta.button">{defaultCopy.finalCta.button}</a>
        </div>

        <div class="mobile-actions">
          <div
            class="language-switch language-switch-mobile"
            aria-label={defaultCopy.header.language.label}
            data-i18n-aria-label="header.language.label"
          >
            <button type="button" data-lang="en" data-i18n="header.language.englishShort">
              {defaultCopy.header.language.englishShort}
            </button>
            <button type="button" data-lang="fil" data-i18n="header.language.filipinoShort">
              {defaultCopy.header.language.filipinoShort}
            </button>
          </div>
          <a href="#download" class="mobile-download" data-i18n="header.mobileDownload">{defaultCopy.header.mobileDownload}</a>
          <button
            type="button"
            class="mobile-menu-btn"
            aria-label={defaultCopy.header.menuAria}
            data-i18n-aria-label="header.menuAria"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </header>

    <main>
      <section id="hero" class="section section-white hero-section">
        <div class="site-shell hero-grid">
          <div class="hero-copy">
            <h1 data-i18n="hero.title">{defaultCopy.hero.title}</h1>
            <p data-i18n="hero.subtitle">{defaultCopy.hero.subtitle}</p>
            <a href="#converter" class="btn-primary" data-i18n="hero.primaryCta">{defaultCopy.hero.primaryCta}</a>
          </div>

          <div id="converter" class="converter-card" aria-label={defaultCopy.converter.title} data-i18n-aria-label="converter.title">
            <div class="converter-block">
              <p class="converter-label" data-i18n="converter.sendAmount">{defaultCopy.converter.sendAmount}</p>
              <div class="converter-row">
                <input id="sendAmount" class="amount-input" type="number" min="0" step="0.01" value="1000" inputmode="decimal" />
                <div class="currency-selector-wrap">
                  <img id="sendFlag" src="/flags/us.svg" alt="" class="flag" aria-hidden="true" />
                  <select id="sendCurrency" class="currency-selector" aria-label={defaultCopy.converter.sendCurrency} data-i18n-aria-label="converter.sendCurrency">
                    {sendCurrencies.map((currency) => (
                      <option value={currency} selected={currency === "USD"}>
                        {currency}
                      </option>
                    ))}
                  </select>
                </div>
              </div>
              <div class="converter-divider"></div>
              <p id="liveRate" class="live-rate">{defaultCopy.converter.liveRatePrefix}: 1 USD = PHP 56.20</p>
              <p id="promoText" class="zero-fee-pill" data-i18n="converter.promo">{defaultCopy.converter.promo}</p>
            </div>

            <div class="converter-block">
              <p class="converter-label" data-i18n="converter.recipientGets">{defaultCopy.converter.recipientGets}</p>
              <div class="converter-row">
                <input id="receiveAmount" class="amount-output" type="text" value="PHP 56,200.00" readonly aria-label="Receive amount" />
                <div class="currency-selector-wrap currency-fixed">
                  <img src="/flags/ph.svg" alt="" class="flag" aria-hidden="true" />
                  <span>PHP</span>
                </div>
              </div>
              <div class="converter-divider"></div>
            </div>
          </div>
        </div>
      </section>

      <section class="section section-white trust-section" aria-label="Trust highlights">
        <div class="site-shell">
          <div class="trust-marquee-wrap">
            <div class="trust-marquee-track">
              <div class="trust-items">
                {trustItems.map((item) => (
                  <span data-i18n={item.key} data-prefix-check="true">✓ {item.text}</span>
                ))}
              </div>
              <div class="trust-items" aria-hidden="true">
                {trustItems.map((item) => (
                  <span data-i18n={item.key} data-prefix-check="true">✓ {item.text}</span>
                ))}
              </div>
            </div>
          </div>

          <ul class="trust-static-list">
            {trustItems.map((item) => (
              <li data-i18n={item.key} data-prefix-check="true">✓ {item.text}</li>
            ))}
          </ul>
        </div>
      </section>

      <section class="section section-lilac rates-section" id="rates">
        <div class="site-shell">
          <h2 class="section-title" data-i18n="savings.title">{defaultCopy.savings.title}</h2>
          <p class="section-subtitle" data-i18n="savings.subtitle">{defaultCopy.savings.subtitle}</p>

          <div class="rates-table-scroll">
            <table class="rates-table" aria-label={defaultCopy.savings.tableAria} data-i18n-aria-label="savings.tableAria">
              <thead>
                <tr>
                  <th scope="col" data-i18n="savings.headers.provider">{defaultCopy.savings.headers.provider}</th>
                  <th scope="col" data-i18n="savings.headers.rate">{defaultCopy.savings.headers.rate}</th>
                  <th scope="col" data-i18n="savings.headers.fee">{defaultCopy.savings.headers.fee}</th>
                  <th scope="col" data-i18n="savings.headers.recipient">{defaultCopy.savings.headers.recipient}</th>
                </tr>
              </thead>
              <tbody>
                {initialRows.map((row) => (
                  <tr
                    class={row.id === "aspora" ? "is-aspora" : undefined}
                    data-provider={row.id}
                    data-margin={row.marginPct}
                    data-fee={row.fee}
                  >
                    <td>{row.name}</td>
                    <td data-cell="rate">{row.effectiveRate.toFixed(2)}</td>
                    <td data-cell="fee">{row.fee === 0 ? defaultCopy.converter.noFee : `US$${row.fee.toFixed(2)}`}</td>
                    <td data-cell="recipient">
                      <div class="recipient-cell-wrap">
                        <span>{`PHP ${row.recipientGets.toLocaleString("en-US", {
                          minimumFractionDigits: 2,
                          maximumFractionDigits: 2,
                        })}`}</span>
                        {row.id === "aspora" && (
                          <span id="saveBadge" class="save-pill">
                            {defaultCopy.savings.savePrefix} {initialSaveValue.toFixed(2)}
                          </span>
                        )}
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p id="tableUpdated" class="table-updated" data-i18n="savings.updatedFallback">
            {defaultCopy.savings.updatedFallback}
          </p>
        </div>
      </section>

      <section class="section section-white stats-section" aria-label={defaultCopy.stats.title} data-i18n-aria-label="stats.title">
        <div class="site-shell stats-grid">
          <article class="stat-item">
            <h3 data-i18n="stats.transferredValue">{defaultCopy.stats.transferredValue}</h3>
            <p data-i18n="stats.transferredLabel">{defaultCopy.stats.transferredLabel}</p>
          </article>
          <article class="stat-item">
            <h3 data-i18n="stats.savedValue">{defaultCopy.stats.savedValue}</h3>
            <p data-i18n="stats.savedLabel">{defaultCopy.stats.savedLabel}</p>
          </article>
          <article class="stat-item">
            <h3 data-i18n="stats.countriesValue">{defaultCopy.stats.countriesValue}</h3>
            <p data-i18n="stats.countriesLabel">{defaultCopy.stats.countriesLabel}</p>
          </article>
        </div>
      </section>

      <section class="section section-white testimonials-section" id="testimonials">
        <div class="site-shell">
          <h2 class="section-title testimonials-title">
            <span data-i18n="testimonials.titlePrefix">{defaultCopy.testimonials.titlePrefix}</span>
            <span class="testimonials-title-highlight" data-i18n="testimonials.titleHighlight">
              {defaultCopy.testimonials.titleHighlight}
            </span>
            <span data-i18n="testimonials.titleSuffix">{defaultCopy.testimonials.titleSuffix}</span>
          </h2>
          <p class="section-subtitle" data-i18n="testimonials.subtitle">{defaultCopy.testimonials.subtitle}</p>

          <div class="testimonial-nav">
            <button
              id="testimonialPrev"
              type="button"
              class="icon-button"
              aria-label={defaultCopy.testimonials.prev}
              data-i18n-aria-label="testimonials.prev"
            >
              ←
            </button>
            <button
              id="testimonialNext"
              type="button"
              class="icon-button"
              aria-label={defaultCopy.testimonials.next}
              data-i18n-aria-label="testimonials.next"
            >
              →
            </button>
          </div>

          <div id="testimonialTrack" class="testimonial-track">
            {defaultCopy.testimonials.cards.slice(0, 3).map((testimonial, index) => (
              <article class="testimonial-card">
                <div class="testimonial-head">
                  <span class="quote-mark" aria-hidden="true">“</span>
                  <div class="flag-pair" aria-hidden="true">
                    <img src={testimonialFlags[index].fromFlag} alt="" class="flag" />
                    <img src={testimonialFlags[index].toFlag} alt="" class="flag" />
                  </div>
                </div>
                <p class="testimonial-quote" data-i18n={`testimonials.cards.${index}.quote`}>{testimonial.quote}</p>
                <p class="testimonial-name" data-i18n={`testimonials.cards.${index}.person`}>{testimonial.person}</p>
                <p class="testimonial-location" data-i18n={`testimonials.cards.${index}.location`}>{testimonial.location}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="security" class="section section-lilac security-section">
        <div class="site-shell security-grid">
          <div class="security-visual" aria-hidden="true">
            <div class="security-visual-card">
              <div class="security-lock">🔒</div>
              <p data-i18n="security.visual">{defaultCopy.security.visual}</p>
            </div>
          </div>

          <div class="security-content">
            <h2 class="section-title" data-i18n="security.title">{defaultCopy.security.title}</h2>
            <p class="section-subtitle security-subtitle" data-i18n="security.alwaysSubtitle">
              {defaultCopy.security.alwaysSubtitle}
            </p>
            <ul class="security-points">
              <li>
                <span class="security-icon">✓</span>
                <span data-i18n="security.point1">{defaultCopy.security.point1}</span>
              </li>
              <li>
                <span class="security-icon">✓</span>
                <span data-i18n="security.point2">{defaultCopy.security.point2}</span>
              </li>
              <li>
                <span class="security-icon">✓</span>
                <span data-i18n="security.point3">{defaultCopy.security.point3}</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <section id="gateway" class="section section-white gateway-section">
        <div class="site-shell gateway-grid">
          <div class="gateway-content">
            <span class="coming-soon-badge" data-i18n="gateway.badge">{defaultCopy.gateway.badge}</span>
            <h2 class="section-title" data-i18n="gateway.title">{defaultCopy.gateway.title}</h2>
            <ul class="gateway-points">
              <li data-i18n="gateway.feature1Body">{defaultCopy.gateway.feature1Body}</li>
              <li data-i18n="gateway.feature2Body">{defaultCopy.gateway.feature2Body}</li>
              <li data-i18n="gateway.feature3Body">{defaultCopy.gateway.feature3Body}</li>
            </ul>
            <a class="btn-primary" href="https://aspora.frill.co/roadmap" target="_blank" rel="noreferrer" data-i18n="gateway.cta">
              {defaultCopy.gateway.cta}
            </a>
          </div>

          <div class="gateway-visual" aria-hidden="true">
            <div class="phone-mockup">
              <div class="phone-notch"></div>
              <div class="phone-screen-card"></div>
              <div class="phone-screen-line"></div>
              <div class="phone-screen-line"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="featured" class="section section-white featured-section">
        <div class="site-shell">
          <h2 class="section-title" data-i18n="media.title">{defaultCopy.media.title}</h2>
          <div class="featured-logos" aria-label="Featured publications">
            {featuredOutlets.map((outlet) => (
              <span>{outlet}</span>
            ))}
          </div>
        </div>
      </section>

      <section id="download" class="section cta-section">
        <div class="site-shell cta-inner">
          <h2 class="section-title" data-i18n="finalCta.title">{defaultCopy.finalCta.title}</h2>
          <p class="section-subtitle" data-i18n="finalCta.subtitle">{defaultCopy.finalCta.subtitle}</p>
          <div class="cta-downloads" aria-label={defaultCopy.finalCta.downloadAria} data-i18n-aria-label="finalCta.downloadAria">
            <a href="#" class="store-badge" aria-label={defaultCopy.finalCta.storeAppleAria} data-i18n-aria-label="finalCta.storeAppleAria">
              <span data-i18n="finalCta.storeApple">{defaultCopy.finalCta.storeApple}</span>
            </a>
            <a href="#" class="store-badge" aria-label={defaultCopy.finalCta.storeGoogleAria} data-i18n-aria-label="finalCta.storeGoogleAria">
              <span data-i18n="finalCta.storeGoogle">{defaultCopy.finalCta.storeGoogle}</span>
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer id="footer" class="site-footer">
      <div class="site-shell footer-inner">
        <div class="footer-top-row">
          <a
            href="#hero"
            class="brand"
            aria-label={defaultCopy.header.brandAria}
            data-i18n-aria-label="header.brandAria"
          >
            <span class="brand-wordmark">Aspora</span>
          </a>
          <div class="cta-downloads" aria-label={defaultCopy.finalCta.downloadAria} data-i18n-aria-label="finalCta.downloadAria">
            <a href="#" class="store-badge" aria-label={defaultCopy.finalCta.storeAppleAria} data-i18n-aria-label="finalCta.storeAppleAria">
              <span data-i18n="finalCta.storeApple">{defaultCopy.finalCta.storeApple}</span>
            </a>
            <a href="#" class="store-badge" aria-label={defaultCopy.finalCta.storeGoogleAria} data-i18n-aria-label="finalCta.storeGoogleAria">
              <span data-i18n="finalCta.storeGoogle">{defaultCopy.finalCta.storeGoogle}</span>
            </a>
          </div>
        </div>

        <nav class="footer-links" aria-label="Footer navigation">
          <a href="#hero" data-i18n="header.nav.sendMoney">{defaultCopy.header.nav.sendMoney}</a>
          <a href="#gateway" data-i18n="header.nav.payBills">{defaultCopy.header.nav.payBills}</a>
          <a href="#security" data-i18n="header.nav.aboutUs">{defaultCopy.header.nav.aboutUs}</a>
          <a href="#footer" data-i18n="header.nav.careers">{defaultCopy.header.nav.careers}</a>
          <a href="#featured" data-i18n="header.nav.blog">{defaultCopy.header.nav.blog}</a>
          <a href="#rates" data-i18n="footer.pesoRates">{defaultCopy.footer.pesoRates}</a>
          <a href="#footer" data-i18n="footer.helpCenter">{defaultCopy.footer.helpCenter}</a>
          <a href="https://aspora.frill.co/roadmap" target="_blank" rel="noreferrer" data-i18n="footer.roadmap">
            {defaultCopy.footer.roadmap}
          </a>
        </nav>

        <div class="country-groups">
          <div class="country-group">
            <p data-i18n="footer.liveIn">{defaultCopy.footer.liveIn}</p>
            <div class="country-chips">
              {liveCountries.map((country) => (
                <span>{country}</span>
              ))}
            </div>
          </div>

          <div class="country-group">
            <p data-i18n="footer.arrivingSoon">{defaultCopy.footer.arrivingSoon}</p>
            <div class="country-chips">
              {arrivingSoonCountries.map((country) => (
                <span>{country}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="footer-legal">
          <p data-i18n="footer.regulatory">{defaultCopy.footer.regulatory}</p>
          <p data-i18n="footer.disclaimer">{defaultCopy.footer.disclaimer}</p>
          <p>
            <span data-i18n="footer.contactLabel">{defaultCopy.footer.contactLabel}</span>
            <a href="mailto:help@aspora.com">help@aspora.com</a>
          </p>
        </div>

        <div class="footer-bottom-row">
          <p data-i18n="footer.copyright">{defaultCopy.footer.copyright}</p>
          <div class="footer-bottom-links">
            <a href="#" data-i18n="footer.privacy">{defaultCopy.footer.privacy}</a>
            <a href="#" data-i18n="footer.terms">{defaultCopy.footer.terms}</a>
            <a href="#">LinkedIn</a>
            <a href="#">X</a>
            <a href="#">Instagram</a>
          </div>
        </div>
      </div>
    </footer>

    <script
      define:vars={{
        translations,
        sendCurrencyFlags,
        referenceAmount,
        fallbackMidRate,
      }}
    >
      const STORAGE_KEY = "aspora-lang";

      let currentLang = localStorage.getItem(STORAGE_KEY) || "en";
      if (!translations[currentLang]) {
        currentLang = "en";
      }

      const languageButtons = Array.from(document.querySelectorAll("[data-lang]"));

      const header = document.getElementById("siteHeader");
      const amountInput = document.getElementById("sendAmount");
      const sendCurrencyInput = document.getElementById("sendCurrency");
      const sendFlag = document.getElementById("sendFlag");
      const liveRateLabel = document.getElementById("liveRate");
      const promoText = document.getElementById("promoText");
      const receiveAmount = document.getElementById("receiveAmount");
      const tableUpdated = document.getElementById("tableUpdated");
      const saveBadge = document.getElementById("saveBadge");
      const testimonialTrack = document.getElementById("testimonialTrack");
      const testimonialPrev = document.getElementById("testimonialPrev");
      const testimonialNext = document.getElementById("testimonialNext");

      let lastScrollY = window.scrollY;
      let usdToPhp = fallbackMidRate;
      let lastUpdatedAt = null;

      const rates = {
        USD: 1,
        GBP: 0.79,
        EUR: 0.92,
        CAD: 1.36,
        SGD: 1.35,
        AED: 3.67,
        PHP: fallbackMidRate,
      };

      const getNestedValue = (source, path) =>
        path.split(".").reduce((accumulator, segment) => {
          if (accumulator === undefined || accumulator === null) {
            return undefined;
          }

          if (Array.isArray(accumulator) && /^\d+$/.test(segment)) {
            return accumulator[Number(segment)];
          }

          return accumulator[segment];
        }, source);

      const t = (path) => {
        const value = getNestedValue(translations[currentLang], path);
        return typeof value === "string" ? value : path;
      };

      const localeForLanguage = () => (currentLang === "fil" ? "fil-PH" : "en-US");

      const handleHeaderOnScroll = () => {
        const currentScroll = window.scrollY;
        const scrollingDown = currentScroll > lastScrollY;
        const beyondThreshold = currentScroll > 80;

        if (header) {
          header.classList.toggle("is-hidden", scrollingDown && beyondThreshold);
        }

        lastScrollY = currentScroll;
      };

      const formatCurrency = (value, currency = "USD") =>
        new Intl.NumberFormat(localeForLanguage(), {
          style: "currency",
          currency,
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }).format(value);

      const formatNumber = (value, digits = 2) =>
        new Intl.NumberFormat(localeForLanguage(), {
          minimumFractionDigits: digits,
          maximumFractionDigits: digits,
        }).format(value);

      const convertRate = (from, to) => {
        if (!rates[from] || !rates[to]) {
          return null;
        }

        return rates[to] / rates[from];
      };

      const updateConverter = () => {
        if (!(amountInput instanceof HTMLInputElement) || !(sendCurrencyInput instanceof HTMLSelectElement)) {
          return;
        }

        const sendAmount = Math.max(Number(amountInput.value) || 0, 0);
        const sendCurrency = sendCurrencyInput.value;
        const routeRate = convertRate(sendCurrency, "PHP") || usdToPhp;
        const recipientValue = sendAmount * routeRate;

        if (receiveAmount instanceof HTMLInputElement) {
          receiveAmount.value = `PHP ${formatNumber(recipientValue)}`;
        }

        if (liveRateLabel) {
          liveRateLabel.textContent = `${t("converter.liveRatePrefix")}: 1 ${sendCurrency} = PHP ${formatNumber(routeRate, 2)}`;
        }

        if (promoText) {
          promoText.textContent = t("converter.promo");
        }

        if (sendFlag instanceof HTMLImageElement) {
          sendFlag.src = sendCurrencyFlags[sendCurrency] || "/flags/us.svg";
        }
      };

      const updateTable = () => {
        const rows = Array.from(document.querySelectorAll("tr[data-provider]"));
        let asporaRecipient = 0;
        let bestCompetitorRecipient = 0;

        rows.forEach((row) => {
          const marginPct = Number(row.getAttribute("data-margin") || 0);
          const fee = Number(row.getAttribute("data-fee") || 0);

          const effectiveRate = usdToPhp * (1 - marginPct / 100);
          const recipientGets = Math.max((referenceAmount - fee) * effectiveRate, 0);

          const rateCell = row.querySelector('[data-cell="rate"]');
          const feeCell = row.querySelector('[data-cell="fee"]');
          const recipientCell = row.querySelector('[data-cell="recipient"] > .recipient-cell-wrap > span');

          if (rateCell) {
            rateCell.textContent = formatNumber(effectiveRate, 2);
          }

          if (feeCell) {
            feeCell.textContent = fee === 0 ? t("converter.noFee") : formatCurrency(fee, "USD");
          }

          if (recipientCell) {
            recipientCell.textContent = `PHP ${formatNumber(recipientGets)}`;
          }

          if (row.getAttribute("data-provider") === "aspora") {
            asporaRecipient = recipientGets;
          } else {
            bestCompetitorRecipient = Math.max(bestCompetitorRecipient, recipientGets);
          }
        });

        const saveValue = Math.max(asporaRecipient - bestCompetitorRecipient, 0);
        if (saveBadge) {
          saveBadge.textContent = `${t("savings.savePrefix")} ${formatNumber(saveValue)}`;
        }
      };

      const formatUpdatedLabel = (isoString) => {
        const date = new Date(isoString);
        if (Number.isNaN(date.getTime())) {
          return t("savings.updatedFallback");
        }

        const time = new Intl.DateTimeFormat("en-GB", {
          hour: "2-digit",
          minute: "2-digit",
          hour12: true,
          timeZone: "Europe/London",
        }).format(date);

        const day = new Intl.DateTimeFormat("en-GB", {
          day: "2-digit",
          month: "2-digit",
          year: "2-digit",
          timeZone: "Europe/London",
        }).format(date);

        return `${t("savings.updated")}: ${time} GMT ${day}`;
      };

      const applyI18n = () => {
        document.querySelectorAll("[data-i18n]").forEach((element) => {
          const key = element.dataset.i18n;
          if (!key) {
            return;
          }

          const translatedText = getNestedValue(translations[currentLang], key);
          if (typeof translatedText === "string") {
            const needsCheckPrefix = element.dataset.prefixCheck === "true";
            element.textContent = needsCheckPrefix ? `✓ ${translatedText}` : translatedText;
          }
        });

        document.querySelectorAll("[data-i18n-aria-label]").forEach((element) => {
          const key = element.dataset.i18nAriaLabel;
          if (!key) {
            return;
          }

          const translatedText = getNestedValue(translations[currentLang], key);
          if (typeof translatedText === "string") {
            element.setAttribute("aria-label", translatedText);
          }
        });
      };

      const setLanguage = (nextLanguage) => {
        if (!translations[nextLanguage]) {
          return;
        }

        currentLang = nextLanguage;
        localStorage.setItem(STORAGE_KEY, currentLang);
        document.documentElement.lang = currentLang === "fil" ? "fil" : "en";

        applyI18n();

        languageButtons.forEach((button) => {
          const isActive = button.dataset.lang === currentLang;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        document.title = t("meta.title");

        const descriptionTag = document.querySelector("meta[name='description']");
        if (descriptionTag) {
          descriptionTag.setAttribute("content", t("meta.description"));
        }

        const ogTitle = document.querySelector("meta[property='og:title']");
        if (ogTitle) {
          ogTitle.setAttribute("content", t("meta.title"));
        }

        const ogDescription = document.querySelector("meta[property='og:description']");
        if (ogDescription) {
          ogDescription.setAttribute("content", t("meta.description"));
        }

        updateConverter();
        updateTable();

        if (tableUpdated) {
          tableUpdated.textContent = lastUpdatedAt ? formatUpdatedLabel(lastUpdatedAt) : t("savings.updatedFallback");
        }
      };

      const fetchRates = async () => {
        try {
          const response = await fetch("/api/rates.json", {
            headers: {
              Accept: "application/json",
            },
          });

          if (!response.ok) {
            return;
          }

          const payload = await response.json();
          if (!payload?.rates?.PHP) {
            return;
          }

          Object.assign(rates, payload.rates);
          lastUpdatedAt = payload.updatedAt || new Date().toISOString();

          const latestUsdPhp = convertRate("USD", "PHP");
          if (latestUsdPhp) {
            usdToPhp = latestUsdPhp;
          }

          if (tableUpdated) {
            tableUpdated.textContent = formatUpdatedLabel(lastUpdatedAt);
          }

          updateConverter();
          updateTable();
        } catch {
          if (tableUpdated) {
            tableUpdated.textContent = t("savings.updatedFallback");
          }
        }
      };

      window.addEventListener("scroll", handleHeaderOnScroll, { passive: true });

      languageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const language = button.dataset.lang;
          if (language) {
            setLanguage(language);
          }
        });
      });

      if (amountInput && sendCurrencyInput) {
        amountInput.addEventListener("input", updateConverter);
        sendCurrencyInput.addEventListener("change", updateConverter);
      }

      testimonialPrev?.addEventListener("click", () => {
        testimonialTrack?.scrollBy({ left: -320, behavior: "smooth" });
      });

      testimonialNext?.addEventListener("click", () => {
        testimonialTrack?.scrollBy({ left: 320, behavior: "smooth" });
      });

      setLanguage(currentLang);
      updateConverter();
      updateTable();
      fetchRates();
    </script>
  </body>
</html>
