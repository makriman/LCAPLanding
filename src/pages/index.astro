---
import "../styles/global.css";

const sendCurrencies = ["USD", "GBP", "EUR", "CAD", "SGD", "AED"];
const sendCurrencyFlags = {
  USD: "/flags/us.svg",
  GBP: "/flags/gb.svg",
  EUR: "/flags/eu.svg",
  CAD: "/flags/ca.svg",
  SGD: "/flags/sg.svg",
  AED: "/flags/ae.svg",
};

const referenceAmount = 1000;
const fallbackMidRate = 56.2;
const tableProviders = [
  { id: "aspora", name: "Aspora", marginPct: 0.15, fee: 3 },
  { id: "remitly", name: "Remitly", marginPct: 1.1, fee: 1.99 },
  { id: "skrill", name: "Skrill", marginPct: 1.3, fee: 0 },
  { id: "wise", name: "Wise", marginPct: 0.2, fee: 5.68 },
  { id: "western-union", name: "Western Union", marginPct: 1.8, fee: 2.5 },
];

const initialRows = tableProviders.map((provider) => {
  const effectiveRate = fallbackMidRate * (1 - provider.marginPct / 100);
  const recipientGets = Math.max((referenceAmount - provider.fee) * effectiveRate, 0);

  return {
    ...provider,
    effectiveRate,
    recipientGets,
  };
});

const asporaBase = initialRows.find((row) => row.id === "aspora")?.recipientGets ?? 0;
const bestCompetitorBase = Math.max(...initialRows.filter((row) => row.id !== "aspora").map((row) => row.recipientGets));
const initialSaveValue = Math.max(asporaBase - bestCompetitorBase, 0);

const testimonials = [
  {
    fromFlag: "/flags/us.svg",
    toFlag: "/flags/ph.svg",
    person: "Joanna R.",
    location: "Nurse, California to Pampanga",
    quote:
      "I switched because my family receives more pesos every month. Transfers land quickly and support is always responsive.",
  },
  {
    fromFlag: "/flags/ca.svg",
    toFlag: "/flags/ph.svg",
    person: "Mark D.",
    location: "Engineer, Toronto to Cebu",
    quote: "Finally a remittance app with clear pricing. No surprises, and my parents get updates in real-time.",
  },
  {
    fromFlag: "/flags/ae.svg",
    toFlag: "/flags/ph.svg",
    person: "Liza M.",
    location: "Caregiver, Dubai to Iloilo",
    quote: "The recurring transfer setup is a game changer. Tuition payments are now on autopilot.",
  },
];

const trustItems = [
  "Never lose money on hidden fees",
  "256-bit encryption on all transfers",
  "24x7 customer support",
];

const featuredOutlets = ["CNBC", "YourStory", "Entrepreneur", "Economic Times", "Gulf News"];
const liveCountries = ["US", "UK", "UAE", "EU", "SG", "PH"];
const arrivingSoonCountries = ["SA", "FR", "ES", "NL", "CA"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Aspora - Money transfers to the Philippines at Google Rates</title>
    <meta
      name="description"
      content="Send money to the Philippines at Google-matching rates, low fees, transparent pricing, and instant transfers for OFWs and global Filipinos."
    />
    <meta property="og:title" content="Aspora - Money transfers to the Philippines at Google Rates" />
    <meta
      property="og:description"
      content="Secure and lightning-fast transfers to the Philippines with transparent pricing and guaranteed Google rates."
    />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Aspora" />
    <meta property="og:url" content="https://www.aspora.com" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header id="siteHeader" class="site-header">
      <div class="site-shell site-header-inner">
        <a href="#hero" class="brand" aria-label="Aspora home">
          <span class="brand-wordmark">Aspora</span>
        </a>

        <nav class="desktop-nav" aria-label="Primary">
          <a href="#hero"
            >OFW banking
            <span class="new-pill">New</span>
          </a>
          <a href="#gateway">Pay bills</a>
          <a href="#security">About us</a>
          <a href="#footer">Careers</a>
          <a href="#featured">Blog</a>
        </nav>

        <div class="desktop-actions">
          <a href="#download" class="btn-primary btn-nav">Download app</a>
        </div>

        <div class="mobile-actions">
          <a href="#download" class="mobile-download">Download</a>
          <button type="button" class="mobile-menu-btn" aria-label="Open menu">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </header>

    <main>
      <section id="hero" class="section section-white hero-section">
        <div class="site-shell hero-grid">
          <div class="hero-copy">
            <h1>Global finance for global Filipinos</h1>
            <p>Secure, lightning fast transfers at guaranteed Google rates.</p>
            <a href="#converter" class="btn-primary">Send money</a>
          </div>

          <div id="converter" class="converter-card" aria-label="Send money converter">
            <div class="converter-block">
              <p class="converter-label">You Send</p>
              <div class="converter-row">
                <input id="sendAmount" class="amount-input" type="number" min="0" step="0.01" value="1000" inputmode="decimal" />
                <div class="currency-selector-wrap">
                  <img id="sendFlag" src="/flags/us.svg" alt="" class="flag" aria-hidden="true" />
                  <select id="sendCurrency" class="currency-selector" aria-label="Send currency">
                    {sendCurrencies.map((currency) => (
                      <option value={currency} selected={currency === "USD"}>
                        {currency}
                      </option>
                    ))}
                  </select>
                </div>
              </div>
              <div class="converter-divider"></div>
              <p id="liveRate" class="live-rate">Live Google rate: 1 USD = PHP 56.20</p>
              <p class="zero-fee-pill">Zero fee for first transfer</p>
            </div>

            <div class="converter-block">
              <p class="converter-label">They receive</p>
              <div class="converter-row">
                <strong id="receiveAmount" class="amount-output">PHP 56,200.00</strong>
                <div class="currency-selector-wrap currency-fixed">
                  <img src="/flags/ph.svg" alt="" class="flag" aria-hidden="true" />
                  <span>PHP</span>
                </div>
              </div>
              <div class="converter-divider"></div>
            </div>
          </div>
        </div>
      </section>

      <section class="section section-white trust-section" aria-label="Trust highlights">
        <div class="site-shell">
          <div class="trust-marquee-wrap">
            <div class="trust-marquee-track">
              <div class="trust-items">
                {trustItems.map((item) => (
                  <span>✓ {item}</span>
                ))}
              </div>
              <div class="trust-items" aria-hidden="true">
                {trustItems.map((item) => (
                  <span>✓ {item}</span>
                ))}
              </div>
            </div>
          </div>

          <ul class="trust-static-list">
            {trustItems.map((item) => (
              <li>✓ {item}</li>
            ))}
          </ul>
        </div>
      </section>

      <section class="section section-lilac rates-section" id="rates">
        <div class="site-shell">
          <h2 class="section-title">Unlock savings with Google rates to the Philippines</h2>
          <p class="section-subtitle">Here's how much US$1,000 gets you with Aspora</p>

          <div class="rates-table-scroll">
            <table class="rates-table" aria-label="Provider comparison table">
              <thead>
                <tr>
                  <th scope="col">Provider</th>
                  <th scope="col">Exchange rate</th>
                  <th scope="col">Transfer fee</th>
                  <th scope="col">Recipient gets</th>
                </tr>
              </thead>
              <tbody>
                {initialRows.map((row) => (
                  <tr
                    class={row.id === "aspora" ? "is-aspora" : undefined}
                    data-provider={row.id}
                    data-margin={row.marginPct}
                    data-fee={row.fee}
                  >
                    <td>{row.name}</td>
                    <td data-cell="rate">{row.effectiveRate.toFixed(2)}</td>
                    <td data-cell="fee">{row.fee === 0 ? "US$0.00" : `US$${row.fee.toFixed(2)}`}</td>
                    <td data-cell="recipient">
                      <div class="recipient-cell-wrap">
                        <span>{`PHP ${row.recipientGets.toLocaleString("en-US", {
                          minimumFractionDigits: 2,
                          maximumFractionDigits: 2,
                        })}`}</span>
                        {row.id === "aspora" && (
                          <span id="saveBadge" class="save-pill">Save PHP {initialSaveValue.toFixed(2)}</span>
                        )}
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p id="tableUpdated" class="table-updated">Last updated at 06:01 PM GMT 29.03.26</p>
        </div>
      </section>

      <section class="section section-white stats-section" aria-label="Aspora impact stats">
        <div class="site-shell stats-grid">
          <article class="stat-item">
            <h3>$2 Bn+</h3>
            <p>Securely transferred worldwide</p>
          </article>
          <article class="stat-item">
            <h3>PHP 8.4 Bn+</h3>
            <p>Saved by our users in forex fees</p>
          </article>
          <article class="stat-item">
            <h3>6 Countries</h3>
            <p>Where we're live and serving OFWs</p>
          </article>
        </div>
      </section>

      <section class="section section-white testimonials-section" id="testimonials">
        <div class="site-shell">
          <h2 class="section-title testimonials-title">
            Trusted by <span>1 million+ OFWs</span> around the world
          </h2>
          <p class="section-subtitle">For seamless and secure transfers</p>

          <div class="testimonial-nav">
            <button id="testimonialPrev" type="button" class="icon-button" aria-label="Previous testimonials">←</button>
            <button id="testimonialNext" type="button" class="icon-button" aria-label="Next testimonials">→</button>
          </div>

          <div id="testimonialTrack" class="testimonial-track">
            {testimonials.map((testimonial) => (
              <article class="testimonial-card">
                <div class="testimonial-head">
                  <span class="quote-mark" aria-hidden="true">“</span>
                  <div class="flag-pair" aria-hidden="true">
                    <img src={testimonial.fromFlag} alt="" class="flag" />
                    <img src={testimonial.toFlag} alt="" class="flag" />
                  </div>
                </div>
                <p class="testimonial-quote">{testimonial.quote}</p>
                <p class="testimonial-name">{testimonial.person}</p>
                <p class="testimonial-location">{testimonial.location}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="security" class="section section-lilac security-section">
        <div class="site-shell security-grid">
          <div class="security-visual" aria-hidden="true">
            <div class="security-visual-card">
              <div class="security-lock">🔒</div>
              <p>Bank-grade security for every peso transfer.</p>
            </div>
          </div>

          <div class="security-content">
            <h2 class="section-title">Security-first. Always.</h2>
            <p class="section-subtitle security-subtitle">Protecting your money at every step</p>
            <ul class="security-points">
              <li>
                <span class="security-icon">✓</span>
                <span>Proactive fraud detection around the clock</span>
              </li>
              <li>
                <span class="security-icon">✓</span>
                <span>Funds held with regulated financial institutions</span>
              </li>
              <li>
                <span class="security-icon">✓</span>
                <span>24x7 customer support</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <section id="gateway" class="section section-white gateway-section">
        <div class="site-shell gateway-grid">
          <div class="gateway-content">
            <span class="coming-soon-badge">Coming soon</span>
            <h2 class="section-title">Your gateway to the Philippines: Send, Pay, Invest</h2>
            <ul class="gateway-points">
              <li>Save in global currencies with up to 9% interest</li>
              <li>Stay on top of your bills without lifting a finger</li>
              <li>Automate your remittances and recurring transfers</li>
            </ul>
            <a class="btn-primary" href="https://aspora.frill.co/roadmap" target="_blank" rel="noreferrer">See roadmap</a>
          </div>

          <div class="gateway-visual" aria-hidden="true">
            <div class="phone-mockup">
              <div class="phone-notch"></div>
              <div class="phone-screen-card"></div>
              <div class="phone-screen-line"></div>
              <div class="phone-screen-line"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="featured" class="section section-white featured-section">
        <div class="site-shell">
          <h2 class="section-title">As featured in</h2>
          <div class="featured-logos" aria-label="Featured publications">
            {featuredOutlets.map((outlet) => (
              <span>{outlet}</span>
            ))}
          </div>
        </div>
      </section>

      <section id="download" class="section cta-section">
        <div class="site-shell cta-inner">
          <h2 class="section-title">Your world. Your money. Get the Aspora app.</h2>
          <p class="section-subtitle">Wherever you're headed, Aspora makes finances simple.</p>
          <div class="cta-downloads" aria-label="App download options">
            <a href="#" class="store-badge" aria-label="Download on the App Store">
              <span>Apple App Store</span>
            </a>
            <a href="#" class="store-badge" aria-label="Get it on Google Play">
              <span>Google Play</span>
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer id="footer" class="site-footer">
      <div class="site-shell footer-inner">
        <div class="footer-top-row">
          <a href="#hero" class="brand" aria-label="Aspora home">
            <span class="brand-wordmark">Aspora</span>
          </a>
          <div class="cta-downloads" aria-label="Footer app download options">
            <a href="#" class="store-badge"><span>App Store</span></a>
            <a href="#" class="store-badge"><span>Google Play</span></a>
          </div>
        </div>

        <nav class="footer-links" aria-label="Footer navigation">
          <a href="#hero">OFW banking</a>
          <a href="#gateway">Pay bills</a>
          <a href="#security">About us</a>
          <a href="#footer">Careers</a>
          <a href="#featured">Blog</a>
          <a href="#rates">Currency rates</a>
          <a href="#footer">Help</a>
          <a href="https://aspora.frill.co/roadmap" target="_blank" rel="noreferrer">Roadmap</a>
        </nav>

        <div class="country-groups">
          <div class="country-group">
            <p>Live in</p>
            <div class="country-chips">
              {liveCountries.map((country) => (
                <span>{country}</span>
              ))}
            </div>
          </div>

          <div class="country-group">
            <p>Arriving soon in</p>
            <div class="country-chips">
              {arrivingSoonCountries.map((country) => (
                <span>{country}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="footer-legal">
          <p>
            Aspora Inc. is a U.S. money services business partner network. Philippine payouts are delivered through licensed banking and
            e-money partners supervised by the Bangko Sentral ng Pilipinas (BSP).
          </p>
          <p>
            Rates, fees, and delivery timelines vary by route, payment method, and partner network. Terms, eligibility, and compliance
            checks apply.
          </p>
          <p>Contact: <a href="mailto:help@aspora.com">help@aspora.com</a></p>
        </div>

        <div class="footer-bottom-row">
          <p>© 2025 Aspora.com (Vance Inc). All rights reserved.</p>
          <div class="footer-bottom-links">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Use</a>
            <a href="#">LinkedIn</a>
            <a href="#">X</a>
            <a href="#">Instagram</a>
          </div>
        </div>
      </div>
    </footer>

    <script
      define:vars={{
        sendCurrencyFlags,
        referenceAmount,
        fallbackMidRate,
      }}
    >
      const header = document.getElementById("siteHeader");
      let lastScrollY = window.scrollY;

      const handleHeaderOnScroll = () => {
        const currentScroll = window.scrollY;
        const scrollingDown = currentScroll > lastScrollY;
        const beyondThreshold = currentScroll > 80;

        if (header) {
          header.classList.toggle("is-hidden", scrollingDown && beyondThreshold);
        }

        lastScrollY = currentScroll;
      };

      window.addEventListener("scroll", handleHeaderOnScroll, { passive: true });

      const rates = {
        USD: 1,
        GBP: 0.79,
        EUR: 0.92,
        CAD: 1.36,
        SGD: 1.35,
        AED: 3.67,
        PHP: fallbackMidRate,
      };

      const amountInput = document.getElementById("sendAmount");
      const sendCurrencyInput = document.getElementById("sendCurrency");
      const sendFlag = document.getElementById("sendFlag");
      const liveRateLabel = document.getElementById("liveRate");
      const receiveAmount = document.getElementById("receiveAmount");
      const tableUpdated = document.getElementById("tableUpdated");
      const saveBadge = document.getElementById("saveBadge");

      let usdToPhp = fallbackMidRate;

      const formatCurrency = (value, currency = "USD") =>
        new Intl.NumberFormat("en-US", {
          style: "currency",
          currency,
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }).format(value);

      const formatNumber = (value, digits = 2) =>
        new Intl.NumberFormat("en-US", {
          minimumFractionDigits: digits,
          maximumFractionDigits: digits,
        }).format(value);

      const convertRate = (from, to) => {
        if (!rates[from] || !rates[to]) {
          return null;
        }

        return rates[to] / rates[from];
      };

      const updateConverter = () => {
        if (!(amountInput instanceof HTMLInputElement) || !(sendCurrencyInput instanceof HTMLSelectElement)) {
          return;
        }

        const sendAmount = Math.max(Number(amountInput.value) || 0, 0);
        const sendCurrency = sendCurrencyInput.value;
        const routeRate = convertRate(sendCurrency, "PHP") || usdToPhp;
        const recipientValue = sendAmount * routeRate;

        if (receiveAmount) {
          receiveAmount.textContent = `PHP ${formatNumber(recipientValue)}`;
        }

        if (liveRateLabel) {
          liveRateLabel.textContent = `Live Google rate: 1 ${sendCurrency} = PHP ${formatNumber(routeRate, 2)}`;
        }

        if (sendFlag instanceof HTMLImageElement) {
          sendFlag.src = sendCurrencyFlags[sendCurrency] || "/flags/us.svg";
        }
      };

      const updateTable = () => {
        const rows = Array.from(document.querySelectorAll("tr[data-provider]"));
        let asporaRecipient = 0;
        let bestCompetitorRecipient = 0;

        rows.forEach((row) => {
          const marginPct = Number(row.getAttribute("data-margin") || 0);
          const fee = Number(row.getAttribute("data-fee") || 0);

          const effectiveRate = usdToPhp * (1 - marginPct / 100);
          const recipientGets = Math.max((referenceAmount - fee) * effectiveRate, 0);

          const rateCell = row.querySelector('[data-cell="rate"]');
          const feeCell = row.querySelector('[data-cell="fee"]');
          const recipientCell = row.querySelector('[data-cell="recipient"] > .recipient-cell-wrap > span');

          if (rateCell) {
            rateCell.textContent = formatNumber(effectiveRate, 2);
          }

          if (feeCell) {
            feeCell.textContent = formatCurrency(fee, "USD");
          }

          if (recipientCell) {
            recipientCell.textContent = `PHP ${formatNumber(recipientGets)}`;
          }

          if (row.getAttribute("data-provider") === "aspora") {
            asporaRecipient = recipientGets;
          } else {
            bestCompetitorRecipient = Math.max(bestCompetitorRecipient, recipientGets);
          }
        });

        const saveValue = Math.max(asporaRecipient - bestCompetitorRecipient, 0);
        if (saveBadge) {
          saveBadge.textContent = `Save PHP ${formatNumber(saveValue)}`;
        }
      };

      const formatUpdatedLabel = (isoString) => {
        const date = new Date(isoString);
        if (Number.isNaN(date.getTime())) {
          return "Last updated at 06:01 PM GMT 29.03.26";
        }

        const time = new Intl.DateTimeFormat("en-GB", {
          hour: "2-digit",
          minute: "2-digit",
          hour12: true,
          timeZone: "Europe/London",
        }).format(date);

        const day = new Intl.DateTimeFormat("en-GB", {
          day: "2-digit",
          month: "2-digit",
          year: "2-digit",
          timeZone: "Europe/London",
        }).format(date);

        return `Last updated at ${time} GMT ${day}`;
      };

      const fetchRates = async () => {
        try {
          const response = await fetch("/api/rates.json", {
            headers: {
              Accept: "application/json",
            },
          });

          if (!response.ok) {
            return;
          }

          const payload = await response.json();
          if (!payload?.rates?.PHP) {
            return;
          }

          Object.assign(rates, payload.rates);

          const latestUsdPhp = convertRate("USD", "PHP");
          if (latestUsdPhp) {
            usdToPhp = latestUsdPhp;
          }

          if (tableUpdated) {
            tableUpdated.textContent = formatUpdatedLabel(payload.updatedAt || new Date().toISOString());
          }

          updateConverter();
          updateTable();
        } catch {
          // no-op fallback
        }
      };

      if (amountInput && sendCurrencyInput) {
        amountInput.addEventListener("input", updateConverter);
        sendCurrencyInput.addEventListener("change", updateConverter);
      }

      const testimonialTrack = document.getElementById("testimonialTrack");
      const testimonialPrev = document.getElementById("testimonialPrev");
      const testimonialNext = document.getElementById("testimonialNext");

      testimonialPrev?.addEventListener("click", () => {
        testimonialTrack?.scrollBy({ left: -320, behavior: "smooth" });
      });

      testimonialNext?.addEventListener("click", () => {
        testimonialTrack?.scrollBy({ left: 320, behavior: "smooth" });
      });

      updateConverter();
      updateTable();
      fetchRates();
    </script>
  </body>
</html>
